      "dotenv": "^17.2.4",
      "express": "^5.2.1",
      "express-rate-limit": "^8.2.1",
      "express-winston": "^4.2.0",
      "helmet": "^8.1.0",
      "ioredis": "^5.4.1",
      "jsonwebtoken": "^9.0.3",
      "kysely": "^0.28.17",
      "mongoose": "^9.2.1",
      "ms": "^2.1.3",
