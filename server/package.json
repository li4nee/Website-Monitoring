   "scripts": {
      "test": "echo \"Error: no test specified\" && exit 1",
      "lint": "eslint .",
      "typecheck": "tsc --noEmit",
      "build": "tsc",
      "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
      "dev:consumer": "nodemon --watch src --ext ts --exec ts-node src/modules/processor/consumerStartup.ts",
      "dev:alerting": "nodemon --watch src --ext ts --exec ts-node src/modules/alerting/worker/alertingWorkerStartup.ts",
      "dev:dlq": "nodemon --watch src --ext ts --exec ts-node src/modules/processor/dlqConsumerStartup.ts",
      "migrate": "ts-node scripts/migrate.ts up",
      "migrate:down": "ts-node scripts/migrate.ts down",
      "sync-indexes": "ts-node scripts/syncMongoIndexes.ts",
      "backfill-api-hit-expiry": "ts-node scripts/backfillApiHitExpiry.ts"
   },
   "keywords": [],
   "author": "",
   "license": "ISC",
   "type": "commonjs",
   "dependencies": {
      "amqplib": "^0.10.9",
      "bcrypt": "^6.0.0",
