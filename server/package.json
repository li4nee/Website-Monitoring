      "@types/cors": "^2.8.19",
      "@types/express": "^5.0.6",
      "@types/jsonwebtoken": "^9.0.10",
      "@types/node": "^25.3.0",
      "@types/nodemailer": "^8.0.0",
      "@types/pg": "^8.16.0",
      "eslint": "^10.6.0",
      "eslint-config-prettier": "^10.1.8",
